rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidBooking(data) {
      return data.id is string && data.id.size() <= 100
        && data.name is string && data.name.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.serviceType is string && data.serviceType.size() <= 200
        && data.brand is string && data.brand.size() <= 100
        && data.issue is string && data.issue.size() <= 2000
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.status is string && (data.status == 'Pending' || data.status == 'Confirmed' || data.status == 'Completed')
        && (!('tech' in data) || (data.tech is string && data.tech.size() <= 200));
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isValidId(bookingId) && isValidBooking(incoming());
      allow update: if isValidId(bookingId) && isValidBooking(incoming());
      allow delete: if true;
    }
  }
}
